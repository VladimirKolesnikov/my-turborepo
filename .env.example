# PostgreSQL
POSTGRES_USER=POSTGRES_USER
POSTGRES_PASSWORD=POSTGRES_PASSWORD
POSTGRES_DB=POSTGRES_DB
POSTGRES_PORT=POSTGRES_PORT
POSTGRES_HOST=POSTGRES_HOST

# DB URL — set this directly OR leave unset and use individual POSTGRES_* vars above.
# dotenv does NOT interpolate shell variables, so the template below won't work as-is.
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

API_AI_PORT=API_AI_PORT
API_GATEWAY_PORT=API_GATEWAY_PORT
API_GATEWAY_INTERNAL_URL=http://127.0.0.1:3001
NEXT_PUBLIC_API_GATEWAY_URL=http://127.0.0.1:3001

# Mastra
MASTRA_PORT=4111
MASTRA_BASE_URL=http://127.0.0.1:4111
MASTRA_MODEL=openai/gpt-4.1-mini

# Redis
REDIS_PASSWORD=REDIS_PASSWORD
REDIS_PORT=REDIS_PORT

# LLM (OpenRouter)
OPENROUTER_API_KEY=YOUR_KEY
OPENROUTER_CHAT_MODEL=inclusionai/ling-2.6-flash:free
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
